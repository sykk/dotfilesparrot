  "editor.tokenColorCustomizations": {
    "comments": {
      "foreground": "#5d9146",
      "fontStyle": "italic"
    },
    "functions": "#8fee56",
    "keywords": "#00ff66",
    "numbers": "#bfe04e",
    "strings": "#79dc4c",
    "textMateRules": [
      {
        "scope": [
          "constant",
          "constant.language",
          "constant.numeric",
          "support.constant"
        ],
        "settings": {
          "foreground": "#bfe04e"
        }
      },
      {
        "scope": [
          "entity.name.function",
          "support.function",
          "meta.function-call"
        ],
        "settings": {
          "foreground": "#8fee56"
        }
      },
      {
        "scope": [
          "entity.name.type",
          "entity.name.class",
          "support.type",
          "storage.type"
        ],
        "settings": {
          "foreground": "#73ffd2"
        }
      },
      {
        "scope": [
          "keyword",
          "storage.modifier",
          "variable.language"
        ],
        "settings": {
          "foreground": "#00ff66"
        }
      },
      {
        "scope": [
          "punctuation",
          "meta.brace",
          "meta.delimiter"
        ],
        "settings": {
          "foreground": "#8ee565"
        }
      },
      {
        "scope": [
          "string",
          "constant.character"
        ],
        "settings": {
          "foreground": "#79dc4c"
        }
      },
      {
        "scope": [
          "variable",
          "variable.other",
          "variable.parameter"
        ],
        "settings": {
          "foreground": "#e5ffd9"
        }
      },
      {
        "scope": [
          "invalid",
          "invalid.illegal"
        ],
        "settings": {
          "foreground": "#ff5060"
        }
      }
    ]
  },
  "workbench.startupEditor": "none"
}
